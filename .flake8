[flake8]
max-line-length = 179
max-complexity = 10
extend-ignore =
    # whitespace before ':'
    E203,
    # line break before binary operator
    W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .eggs,
    *.egg,
    build,
    dist
per-file-ignores =
    # imported but unused
    __init__.py: F401
